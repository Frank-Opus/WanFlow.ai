# Compose/runtime
PORT=3010
HOST=0.0.0.0
NODE_ENV=production

# Host storage path used by docker compose volume binding.
# Override to an absolute host path on HKZ if you do not want to keep data beside the repo.
WANFLOW_PLATFORM_HOST_DIR=./platform-data

# In-container writable storage paths
WANFLOW_PLATFORM_DIR=/data/wanflow-platform
WANFLOW_MARKETING_LEADS_DIR=/data/wanflow-platform/marketing-leads

# Core runtime
WANFLOW_QWEN_API_KEY=replace-with-production-key
WANFLOW_PYTHON_BIN=/opt/venv/bin/python
WANFLOW_BASE_URL=http://35.220.164.252:3888/v1/
WANFLOW_DEFAULT_MODEL=Qwen/Qwen3-235B-A22B-Thinking-2507
# Optional: skip live /models probe during boot only if the upstream catalog is intentionally unavailable.
WANFLOW_SKIP_MODEL_CATALOG_CHECK=0

# Standard auth
WANFLOW_SESSION_COOKIE=wanflow_session
WANFLOW_SESSION_SECRET=replace-with-a-32-char-random-secret
WANFLOW_SESSION_TTL_SECONDS=43200
WANFLOW_ADMIN_EMAIL=wanflow@163.com
WANFLOW_ADMIN_PASSWORD=replace-with-production-password
WANFLOW_ADMIN_NAME=Frank Xu
WANFLOW_ADMIN_ROLE=owner

# Future enterprise auth seam
WANFLOW_AUTH_ENABLE_OAUTH=0
WANFLOW_AUTH_SSO_HINT=reserved-for-enterprise-sso
